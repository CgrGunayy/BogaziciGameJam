  dialog:
  - speaker: {fileID: 11400000, guid: fef38f5db5b0d8545b45e7fe71f806f9, type: 2}
    content: "Merhaba, nas\u0131ls\u0131n\u0131z bay\u0131m!"
    onAutomaticSkip: 1
    automaticSkipDelay: 3
    speechSound: {fileID: 8300000, guid: e31df2f95d653a446a0590d8c88e9a01, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Te\u015Fekk\xFCrler ama bu saatte burada olmana ailen izin veriyor
      mu?"
    onAutomaticSkip: 1
    automaticSkipDelay: 5
    speechSound: {fileID: 8300000, guid: 9d17b968f060c914fb80a17581056a5c, type: 3}
  - speaker: {fileID: 11400000, guid: fef38f5db5b0d8545b45e7fe71f806f9, type: 2}
    content: B-ben de tam eve gidecektim.
    onAutomaticSkip: 1
    automaticSkipDelay: 4
    speechSound: {fileID: 8300000, guid: d8730229d88bd7f49936fb98255d9edd, type: 3}
  onlyOneDialog: 1
