  m_Script: {fileID: 11500000, guid: fc617bdf26bf4a4458bd04d5f9bf9d1e, type: 3}
  m_Name: TukanDialog01
  m_EditorClassIdentifier: 
  dialog:
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Aa sen \u015Fu afi\u015Fteki \u015Fark\u0131c\u0131 de\u011Fil misin?"
    onAutomaticSkip: 1
    automaticSkipDelay: 2
    speechSound: {fileID: 8300000, guid: 89fe2a13351ce1349a8bd6d62b891da5, type: 3}
  - speaker: {fileID: 11400000, guid: 21a74d1fe56c82041b59bb697faffa7a, type: 2}
    content: "\u015Euan pek de havamda de\u011Filim."
    onAutomaticSkip: 1
    automaticSkipDelay: 2
    speechSound: {fileID: 8300000, guid: 4890c334a577fc448bfd020ce4d02212, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Hay\u0131rd\u0131r, ne oldu ki?"
    onAutomaticSkip: 1
    automaticSkipDelay: 2
    speechSound: {fileID: 8300000, guid: 7abd0c3eaffa2844eba991791537ea81, type: 3}
  - speaker: {fileID: 11400000, guid: 21a74d1fe56c82041b59bb697faffa7a, type: 2}
    content: Konsere gitmem gerekiyor fakat korkuyorum.
    onAutomaticSkip: 1
    automaticSkipDelay: 3
    speechSound: {fileID: 8300000, guid: 2c60c06ae57611e40b4e489648bc7f0e, type: 3}
  - speaker: {fileID: 11400000, guid: 21a74d1fe56c82041b59bb697faffa7a, type: 2}
    content: "Birileri beni tehdit ediyor ve \u015Fakalar\u0131 yok san\u0131r\u0131m."
    onAutomaticSkip: 1
    automaticSkipDelay: 5
    speechSound: {fileID: 8300000, guid: 1bb0ef876dc98eb47ab8181415dd23a9, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: "Onu gitmeye ikna etmelisin. Hayranlar\u0131n\u0131 \xFCzmek istemeyiz."
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: b37e323b5247a4d468aaa4ffc324c845, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Hayranlar\u0131 m\u0131?"
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: ad2f1d0f048af2247acd74aaccf949a5, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: "Bo\u015Fver \u015Fimdi onu. Hadi \xE7abuk onu ikna et."
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: 21fad7cdf04c1424392dc6031fb77b93, type: 3}
  onlyOneDialog: 1
  dialogFinishEvent:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 11400000, guid: a1bf299cfc8905a469b68833dd0d34fe, type: 2}
        m_MethodName: LoadMinigame
        m_Mode: 3
