  m_Script: {fileID: 11500000, guid: fc617bdf26bf4a4458bd04d5f9bf9d1e, type: 3}
  m_Name: IntroDialog02
  m_EditorClassIdentifier: 
  dialog:
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: O da ne!?
    onAutomaticSkip: 1
    automaticSkipDelay: 1.5
    speechSound: {fileID: 8300000, guid: 42a0219cc8717ba4695d65166d048b82, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: Hey, beni dinle!
    onAutomaticSkip: 1
    automaticSkipDelay: 2
    speechSound: {fileID: 8300000, guid: d2819ff94b6e2c5448b95728f01b63d5, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: "Ufak bir sorunumuz var ve senden yard\u0131m istiyoruz."
    onAutomaticSkip: 1
    automaticSkipDelay: 3
    speechSound: {fileID: 8300000, guid: b37e323b5247a4d468aaa4ffc324c845, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: "Bu d\xFCnyada \xE7ok fazla k\xF6t\xFCl\xFCk yap\u0131lmaya ba\u015Fland\u0131
      ve dengeyi sadece iyilik yaparak sa\u011Flayabiliriz."
    onAutomaticSkip: 1
    automaticSkipDelay: 5.5
    speechSound: {fileID: 8300000, guid: f81e5e4e458c29a4d9a759c38dfde992, type: 3}
  - speaker: {fileID: 11400000, guid: acf6a4e0431fd39438f0710946e90855, type: 2}
    content: "O y\xFCzden seni se\xE7tim ve sana iyilik yapmanda yard\u0131m edece\u011Fim."
    onAutomaticSkip: 1
    automaticSkipDelay: 4
    speechSound: {fileID: 8300000, guid: d2819ff94b6e2c5448b95728f01b63d5, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Hm... \u0130yi o zaman."
    onAutomaticSkip: 1
    automaticSkipDelay: 2
    speechSound: {fileID: 8300000, guid: 42a0219cc8717ba4695d65166d048b82, type: 3}
  onlyOneDialog: 1
  dialogFinishEvent:
    m_PersistentCalls:
      m_Calls: []
