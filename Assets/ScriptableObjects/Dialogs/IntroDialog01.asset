  dialog:
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Ah belim \xE7ok a\u011Fr\u0131yor!"
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: 42a0219cc8717ba4695d65166d048b82, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Belki de koltukta yatmaktan vazge\xE7meliyim."
    onAutomaticSkip: 1
    automaticSkipDelay: 4
    speechSound: {fileID: 8300000, guid: 9d17b968f060c914fb80a17581056a5c, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "\u015Eu 3 g\xFCn de \xF6lmezsem, maa\u015F\u0131mla kendime bir yatak
      alabilirim."
    onAutomaticSkip: 1
    automaticSkipDelay: 4
    speechSound: {fileID: 8300000, guid: ad2f1d0f048af2247acd74aaccf949a5, type: 3}
  onlyOneDialog: 1
