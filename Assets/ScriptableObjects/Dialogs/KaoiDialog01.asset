--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fc617bdf26bf4a4458bd04d5f9bf9d1e, type: 3}
  m_Name: KaoiDialog01
  m_EditorClassIdentifier: 
  dialog:
  - speaker: {fileID: 11400000, guid: 8aaf726a5b90da64e90065dd5215e8dd, type: 2}
    content: "\u015E\u015Ft karde\u015F! sen baksana bir."
    onAutomaticSkip: 1
    automaticSkipDelay: 2.5
    speechSound: {fileID: 8300000, guid: 2c60c06ae57611e40b4e489648bc7f0e, type: 3}
  - speaker: {fileID: 11400000, guid: 8aaf726a5b90da64e90065dd5215e8dd, type: 2}
    content: "Sen \u015Fu ilerideki markette mi \xE7al\u0131\u015F\u0131yorsun?"
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: 4890c334a577fc448bfd020ce4d02212, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "Evet abi hay\u0131rd\u0131r, niye sordun?"
    onAutomaticSkip: 1
    automaticSkipDelay: 3.5
    speechSound: {fileID: 8300000, guid: 89fe2a13351ce1349a8bd6d62b891da5, type: 3}
  - speaker: {fileID: 11400000, guid: 8aaf726a5b90da64e90065dd5215e8dd, type: 2}
    content: "Bo\u015Fver sen \u015Fimdi onu, s\xF6yle bakay\u0131m ka\xE7ta kapat\u0131yorsunuz
      siz?"
    onAutomaticSkip: 1
    automaticSkipDelay: 5
    speechSound: {fileID: 8300000, guid: 1bb0ef876dc98eb47ab8181415dd23a9, type: 3}
  - speaker: {fileID: 11400000, guid: 4af53f861546d414a9d3738d061212ea, type: 2}
    content: "23:30 gibi kapat\u0131yoruz."
    onAutomaticSkip: 1
    automaticSkipDelay: 3
    speechSound: {fileID: 8300000, guid: 9d17b968f060c914fb80a17581056a5c, type: 3}
  - speaker: {fileID: 11400000, guid: 8aaf726a5b90da64e90065dd5215e8dd, type: 2}
    content: "\u0130yi tamam. Hadi sana kolay gelsin."
    onAutomaticSkip: 1
    automaticSkipDelay: 3
    speechSound: {fileID: 8300000, guid: 2c60c06ae57611e40b4e489648bc7f0e, type: 3}
  onlyOneDialog: 1
  dialogFinishEvent:
    m_PersistentCalls:
      m_Calls: []
